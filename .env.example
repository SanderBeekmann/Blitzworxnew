# Site URL voor blitzworx.nl (verplicht voor productie)
# Gebruikt voor: sitemap, robots.txt, canonical URLs, Open Graph, JSON-LD
NEXT_PUBLIC_SITE_URL=https://blitzworx.nl

# Contact form: Resend (required for contact form to send emails)
# Get your API key at https://resend.com/api-keys
# Verify contact@blitzworx.nl in Resend dashboard to send from that address
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=contact@blitzworx.nl

# Supabase (required voor contactformulier + availability)
# Contactformulier schrijft direct naar contact_metadata / calendar_events /
# onboarding_sessions / notifications. Zelfde project als blitzworx-dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://oldreitxkoplawcswzbx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google PageSpeed Insights API (gratis website score tool)
# Aanmaken via: https://console.cloud.google.com/apis/credentials
# Activeer "PageSpeed Insights API" in het project
GOOGLE_PAGESPEED_API_KEY=

# Anthropic Claude API (AI content/marketing analyse in website score tool)
# Aanmaken via: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Firecrawl (website scraping met JS rendering)
# Aanmaken via: https://firecrawl.dev - gratis tier: 500 credits/maand
FIRECRAWL_API_KEY=

# Google Gemini AI (legacy - alleen als fallback, vervangen door Claude)
# GEMINI_API_KEY=

# Analytics (Google Analytics 4)
# Aanmaken via: https://analytics.google.com > Admin > Data Streams > Web
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Visitor tracking (server-side beacon -> Supabase -> blitzworx-dashboard)
# IP_SALT: random 32-byte hex, gebruikt om bezoekers-IPs te hashen
# Genereer met: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT=
# ipinfo.io REST API token voor reverse-IP lookup (B2B bedrijfsnaam)
# Aanmaken via: https://ipinfo.io/signup - gratis tier: 50k requests/maand
IPINFO_TOKEN=
# Optioneel: SHA256 ip-hashes (komma-gescheiden) van eigen IPs zodat je eigen bezoeken niet meetelt
OWNER_IP_HASHES=
